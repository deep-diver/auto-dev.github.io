---
import { SITE_BASE, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
  <nav>
    <a class="brand" href={`${SITE_BASE}/`}>{SITE_TITLE}</a>
    <div class="nav-links">
      <HeaderLink href={`${SITE_BASE}/`}>Home</HeaderLink>
      <HeaderLink href={`${SITE_BASE}/blog`}>Blog</HeaderLink>
      <HeaderLink href={`${SITE_BASE}/about`}>About</HeaderLink>
    </div>
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle theme">◐</button>
  </nav>
</header>

<script is:inline>
  const root = document.documentElement;
  const button = document.getElementById('theme-toggle');
  const applyTheme = (theme) => {
    root.dataset.theme = theme;
    localStorage.setItem('theme', theme);
    if (button) button.setAttribute('aria-label', `Switch to ${theme === 'dark' ? 'light' : 'dark'} mode`);
  };
  button?.addEventListener('click', () => {
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    applyTheme(next);
  });
  applyTheme(root.dataset.theme || 'light');
</script>
