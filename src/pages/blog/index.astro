---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_BASE, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <span class="eyebrow">Archive</span>
        <div class="hero-grid">
          <div>
            <h1>Writing about software without making it boring.</h1>
            <p>Notes on building, shipping, debugging, and occasionally regretting all three.</p>
          </div>
          <div class="note-card">
            <strong>{posts.length}</strong>
            <p>posts ready to publish, extend, or rewrite once better ideas arrive.</p>
          </div>
        </div>
      </section>

      <section class="post-list">
        {posts.map((post) => (
          <a class="post-card" href={`${SITE_BASE}/blog/${post.id}/`}>
            <div class="meta">
              <FormattedDate date={post.data.pubDate} />
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="tags">
                {post.data.tags.map((tag) => <span>{tag}</span>)}
              </div>
            )}
          </a>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>
